# Supabase — Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # NEVER expose to client

# External APIs
EVENTBRITE_API_KEY=your-eventbrite-key
TICKETMASTER_API_KEY=your-ticketmaster-key
OPENAI_API_KEY=your-openai-key               # Free Moderation API only
MAPBOX_SECRET_TOKEN=your-mapbox-secret-token # Server-side geocoding proxy

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173
